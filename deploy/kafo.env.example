ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5000

# Use an absolute protected path in production.
ConnectionStrings__DefaultConnection=Data Source=/var/lib/kafo/kafo.db;Cache=Shared
Security__PublicBaseUrl=https://kafoo.org.sa
Security__PrivateStoragePath=/var/lib/kafo/secure-uploads
Security__DataProtectionKeysPath=/var/lib/kafo/data-protection-keys
Security__LogPath=/var/log/kafo

Email__Smtp__Host=mail.kafoo.org.sa
Email__Smtp__Port=465
Email__Smtp__EnableSsl=true
Email__Smtp__UserName=support@kafoo.org.sa
Email__Smtp__Password=CHANGE_ME_IN_SECRET_STORE
Email__Smtp__FromEmail=support@kafoo.org.sa
Email__Notifications__PublicBaseUrl=https://kafoo.org.sa

MalwareScanning__Enabled=true
MalwareScanning__FailClosed=true
MalwareScanning__Host=127.0.0.1
MalwareScanning__Port=3310

ReverseProxy__KnownProxies__0=127.0.0.1
ReverseProxy__KnownProxies__1=::1

# Set these only on the first empty-database boot, then delete/unset them.
BootstrapAdmin__FullName=مدير النظام
BootstrapAdmin__UserName=admin
BootstrapAdmin__Email=admin@example.org
BootstrapAdmin__Password=CHANGE_ME_STRONG_ONE_TIME_PASSWORD
