limit_req_zone $binary_remote_addr zone=kafo_auth:10m rate=10r/m;

server {
    listen 80;
    server_name kafoo.org.sa www.kafoo.org.sa;
    return 301 https://kafoo.org.sa$request_uri;
}

server {
    listen 443 ssl http2;
    server_name kafoo.org.sa www.kafoo.org.sa;

    ssl_certificate     /etc/letsencrypt/live/kafoo.org.sa/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/kafoo.org.sa/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    server_tokens off;

    client_max_body_size 110m;

    location ~ ^/(Admin|Portal)/(Login|VerifyOtp|ResendOtp) {
        limit_req zone=kafo_auth burst=5 nodelay;
        proxy_pass http://127.0.0.1:5000;
        include proxy_params;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $host;
    }

    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $host;
        proxy_set_header X-Request-ID $request_id;
    }
}
