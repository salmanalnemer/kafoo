@model Kafo.Web.Models.LicenseDocument

@{
    ViewData["Title"] = "إضافة ترخيص";
}

<div class="admin-page-head">
    <div>
        <span>تراخيص الجمعية</span>
        <h1>إضافة ترخيص جديد</h1>
        <p>ارفع الترخيص كصورة أو PDF وسيتم عرضه مباشرة في الموقع.</p>
    </div>

    <a class="admin-back-link" href="/Admin/Licenses">العودة للقائمة</a>
</div>

<div class="admin-form-card">
    <form method="post" enctype="multipart/form-data" class="admin-form">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Title">عنوان الترخيص</label>
                <input asp-for="Title" placeholder="مثال: ترخيص المركز الوطني" />
                <span asp-validation-for="Title"></span>
            </div>

            <div class="form-group">
                <label asp-for="DisplayOrder">الترتيب</label>
                <input asp-for="DisplayOrder" type="number" />
            </div>

            <div class="form-group full">
                <label asp-for="Description">وصف مختصر</label>
                <textarea asp-for="Description" rows="4" placeholder="وصف اختياري للترخيص"></textarea>
            </div>

            <div class="form-group full">
                <label>ملف الترخيص</label>
                <input type="file" name="licenseFile" accept=".jpg,.jpeg,.png,.webp,.pdf" required />
                <small>المسموح: صورة أو PDF. الحد الأعلى 20MB.</small>
            </div>

            <div class="form-check full">
                <input asp-for="IsActive" />
                <label asp-for="IsActive">مفعل</label>
            </div>
        </div>

        <div class="form-actions">
            <button class="admin-submit-btn" type="submit">حفظ الترخيص</button>
            <a href="/Admin/Licenses">إلغاء</a>
        </div>
    </form>
</div>
