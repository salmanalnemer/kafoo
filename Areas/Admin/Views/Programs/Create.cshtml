@model Kafo.Web.Models.ProgramProject

@{
    ViewData["Title"] = "إضافة برنامج أو مشروع";
    var categories = new[] { "برنامج", "مشروع", "مبادرة", "خدمة" };
}

<div class="admin-page-head">
    <div>
        <span>البرامج والمشاريع</span>
        <h1>إضافة برنامج أو مشروع</h1>
        <p>أدخل بيانات البرنامج أو المشروع ليظهر في الموقع العام.</p>
    </div>

    <a class="admin-back-link" href="/Admin/Programs">العودة للقائمة</a>
</div>

<div class="program-form-layout">
    <div class="admin-form-card">
        <form method="post" enctype="multipart/form-data" class="admin-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Title">اسم البرنامج أو المشروع</label>
                    <input asp-for="Title" placeholder="مثال: برنامج العلاج الطبيعي" />
                    <span asp-validation-for="Title"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Category">النوع</label>
                    <select asp-for="Category">
                        @foreach (var category in categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Beneficiaries">الفئة المستهدفة</label>
                    <input asp-for="Beneficiaries" placeholder="مثال: ذوي الإعاقة" />
                </div>

                <div class="form-group">
                    <label asp-for="BeneficiariesCount">عدد المستفيدين</label>
                    <input asp-for="BeneficiariesCount" placeholder="مثال: 50 مستفيد" />
                </div>

                <div class="form-group">
                    <label asp-for="Sector">القطاع</label>
                    <input asp-for="Sector" placeholder="مثال: التأهيل والرعاية" />
                </div>

                <div class="form-group">
                    <label asp-for="DisplayOrder">الترتيب</label>
                    <input asp-for="DisplayOrder" type="number" />
                </div>

                <div class="form-group full">
                    <label asp-for="Description">الوصف المختصر</label>
                    <textarea asp-for="Description" rows="4" placeholder="وصف مختصر يظهر داخل بطاقة البرنامج"></textarea>
                    <span asp-validation-for="Description"></span>
                </div>

                <div class="form-group full">
                    <label asp-for="Details">التفاصيل الكاملة</label>
                    <textarea asp-for="Details" rows="9" placeholder="اكتب تفاصيل البرنامج، الأهداف، آلية التنفيذ، الأثر المتوقع..."></textarea>
                </div>

                <div class="form-group full">
                    <label asp-for="ExternalUrl">رابط خارجي اختياري</label>
                    <input asp-for="ExternalUrl" placeholder="https://..." dir="ltr" />
                </div>

                <div class="form-group full">
                    <label>صورة البرنامج أو المشروع</label>
                    <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.webp" />
                    <small>المقاس المقترح 900×600.</small>
                </div>

                <div class="form-check full">
                    <input asp-for="IsActive" />
                    <label asp-for="IsActive">مفعل</label>
                </div>
            </div>

            <div class="form-actions">
                <button class="admin-submit-btn" type="submit">حفظ البرنامج</button>
                <a href="/Admin/Programs">إلغاء</a>
            </div>
        </form>
    </div>

    <aside class="program-admin-note">
        <span>ملاحظة</span>
        <h2>عرض البرنامج</h2>
        <p>سيظهر البرنامج كبطاقة في صفحة البرامج والمشاريع، مع صفحة تفاصيل مستقلة لكل برنامج.</p>
    </aside>
</div>
