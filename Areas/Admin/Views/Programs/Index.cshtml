@model IReadOnlyList<Kafo.Web.Models.ProgramProject>

@{
    ViewData["Title"] = "البرامج والمشاريع";
}

<div class="admin-page-head">
    <div>
        <span>البرامج والخدمات</span>
        <h1>البرامج والمشاريع</h1>
        <p>إدارة البرامج والمشاريع والمبادرات والخدمات الظاهرة في الموقع العام.</p>
    </div>

    <div class="admin-head-actions">
        <a class="admin-back-link" href="/Programs" target="_blank" rel="noopener noreferrer">معاينة الصفحة</a>
        <a class="admin-main-action" href="/Admin/Programs/Create">إضافة برنامج / مشروع</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="admin-alert-success">@TempData["Success"]</div>
}

<div class="program-admin-grid">
    @if (Model.Any())
    {
        foreach (var item in Model)
        {
            <article class="program-admin-card @(item.IsActive ? "" : "disabled")">
                <div class="program-admin-image">
                    @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                    {
                        <img src="@item.ImagePath" alt="@item.Title" />
                    }
                    else
                    {
                        <strong>@item.Category</strong>
                    }

                    <span>@item.Category</span>
                </div>

                <div class="program-admin-body">
                    <h2>@item.Title</h2>
                    <p>@item.Description</p>

                    <div class="program-admin-meta">
                        <span>الترتيب: @item.DisplayOrder</span>

                        @if (item.IsActive)
                        {
                            <span class="dash-status active">مفعل</span>
                        }
                        else
                        {
                            <span class="dash-status inactive">غير مفعل</span>
                        }
                    </div>

                    <div class="program-admin-actions">
                        <a class="admin-small-btn purple" href="/Admin/Programs/Edit/@item.Id">تعديل</a>
                        <a class="admin-small-btn green" href="/Programs/Details/@item.Id" target="_blank" rel="noopener noreferrer">عرض</a>

                        <form method="post" action="/Admin/Programs/ToggleStatus/@item.Id">
                            @Html.AntiForgeryToken()
                            <button class="admin-small-btn green" type="submit">
                                @(item.IsActive ? "إخفاء" : "إظهار")
                            </button>
                        </form>

                        <form method="post" action="/Admin/Programs/Delete/@item.Id" data-confirm="هل أنت متأكد من حذف البرنامج أو المشروع؟">
                            @Html.AntiForgeryToken()
                            <button class="admin-small-btn danger" type="submit">حذف</button>
                        </form>
                    </div>
                </div>
            </article>
        }
    }
    else
    {
        <div class="dash-empty">لا توجد برامج أو مشاريع حتى الآن.</div>
    }
</div>
