@model Kafo.Web.Models.ProgramProject

@{
    ViewData["Title"] = "تعديل برنامج أو مشروع";
    var categories = new[] { "برنامج", "مشروع", "مبادرة", "خدمة" };
}

<div class="admin-page-head">
    <div>
        <span>البرامج والمشاريع</span>
        <h1>تعديل البرنامج أو المشروع</h1>
        <p>تعديل بيانات البرنامج أو المشروع وصورته ومحتواه التفصيلي.</p>
    </div>

    <a class="admin-back-link" href="/Admin/Programs">العودة للقائمة</a>
</div>

<div class="program-form-layout">
    <div class="admin-form-card">
        <form method="post" enctype="multipart/form-data" class="admin-form">
            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />
            <input asp-for="ImagePath" type="hidden" />
            <input asp-for="CreatedAt" type="hidden" />
            <input asp-for="UpdatedAt" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
            {
                <div class="admin-image-preview">
                    <span>الصورة الحالية</span>
                    <img src="@Model.ImagePath" alt="@Model.Title" />
                </div>
            }

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Title">اسم البرنامج أو المشروع</label>
                    <input asp-for="Title" />
                    <span asp-validation-for="Title"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Category">النوع</label>
                    <select asp-for="Category">
                        @foreach (var category in categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Beneficiaries">الفئة المستهدفة</label>
                    <input asp-for="Beneficiaries" />
                </div>

                <div class="form-group">
                    <label asp-for="BeneficiariesCount">عدد المستفيدين</label>
                    <input asp-for="BeneficiariesCount" />
                </div>

                <div class="form-group">
                    <label asp-for="Sector">القطاع</label>
                    <input asp-for="Sector" />
                </div>

                <div class="form-group">
                    <label asp-for="DisplayOrder">الترتيب</label>
                    <input asp-for="DisplayOrder" type="number" />
                </div>

                <div class="form-group full">
                    <label asp-for="Description">الوصف المختصر</label>
                    <textarea asp-for="Description" rows="4"></textarea>
                    <span asp-validation-for="Description"></span>
                </div>

                <div class="form-group full">
                    <label asp-for="Details">التفاصيل الكاملة</label>
                    <textarea asp-for="Details" rows="9"></textarea>
                </div>

                <div class="form-group full">
                    <label asp-for="ExternalUrl">رابط خارجي اختياري</label>
                    <input asp-for="ExternalUrl" dir="ltr" />
                </div>

                <div class="form-group full">
                    <label>استبدال الصورة</label>
                    <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.webp" />
                    <small>اتركه فارغاً للاحتفاظ بالصورة الحالية.</small>
                </div>

                <div class="form-check full">
                    <input asp-for="IsActive" />
                    <label asp-for="IsActive">مفعل</label>
                </div>
            </div>

            <div class="form-actions">
                <button class="admin-submit-btn" type="submit">حفظ التعديل</button>
                <a href="/Admin/Programs">إلغاء</a>
            </div>
        </form>
    </div>

    <aside class="program-admin-note">
        <span>معاينة</span>
        <h2>@Model.Title</h2>
        <p>@Model.Description</p>
    </aside>
</div>
