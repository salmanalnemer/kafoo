@model Kafo.Web.Models.ServiceLink

@{
    ViewData["Title"] = "إضافة رابط خدمة";
    var categories = new[] { "خدمة إلكترونية", "نموذج", "طلب خدمة", "دعم المستفيدين", "تطوع", "تواصل", "تبرع" };
    var internalPages = new Dictionary<string, string>
    {
        ["/"] = "الرئيسية",
        ["/About"] = "من نحن",
        ["/Vision"] = "الرؤية والرسالة",
        ["/President"] = "كلمة رئيس الجمعية",
        ["/ExecutiveManager"] = "كلمة المدير التنفيذي",
        ["/Team"] = "فريق العمل",
        ["/Licenses"] = "تراخيص الجمعية",
        ["/OrganizationalStructure"] = "الهيكل التنظيمي",
        ["/BankAccounts"] = "الحسابات البنكية",
        ["/Programs"] = "البرامج والمشاريع",
        ["/ServiceLinks"] = "روابط الخدمات",
        ["/NewBeneficiaryRegistration"] = "تسجيل مستفيد جديد",
        ["/BeneficiaryDataUpdate"] = "تحديث بيانات المستفيدين"
    };
}

<div class="admin-page-head">
    <div>
        <span>روابط الخدمات</span>
        <h1>إضافة رابط خدمة</h1>
        <p>اختر هل الرابط صفحة داخل الموقع أو رابط خارجي، وسيظهر تلقائياً في قائمة الخدمات الإلكترونية.</p>
    </div>

    <a class="admin-back-link" href="/Admin/ServiceLinks">العودة للقائمة</a>
</div>

<div class="service-form-layout">
    <div class="admin-form-card">
        <form method="post" enctype="multipart/form-data" class="admin-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Title">عنوان الخدمة</label>
                    <input asp-for="Title" placeholder="مثال: تسجيل مستفيد" />
                    <span asp-validation-for="Title"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Category">التصنيف</label>
                    <select asp-for="Category">
                        @foreach (var category in categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="LinkType">نوع الرابط</label>
                    <select asp-for="LinkType" id="linkTypeSelect">
                        <option value="External">رابط خارجي</option>
                        <option value="Internal">صفحة داخل الموقع</option>
                    </select>
                </div>

                <div class="form-group link-external-box">
                    <label>الرابط الخارجي</label>
                    <input name="externalUrl" dir="ltr" placeholder="https://example.com" />
                </div>

                <div class="form-group link-internal-box" style="display:none;">
                    <label asp-for="InternalPath">اختر صفحة من داخل الموقع</label>
                    <select asp-for="InternalPath">
                        <option value="">اختر الصفحة</option>
                        @foreach (var internalPage in internalPages)
                        {
                            <option value="@internalPage.Key">@internalPage.Value</option>
                        }
                    </select>
                </div>

                <div class="form-group full">
                    <label asp-for="Description">وصف الخدمة</label>
                    <textarea asp-for="Description" rows="4" placeholder="وصف مختصر يظهر داخل بطاقة الخدمة"></textarea>
                    <span asp-validation-for="Description"></span>
                </div>

                <div class="form-group">
                    <label asp-for="TargetAudience">الفئة المستهدفة</label>
                    <input asp-for="TargetAudience" placeholder="مثال: المستفيدين" />
                </div>

                <div class="form-group">
                    <label asp-for="ButtonText">نص الزر</label>
                    <input asp-for="ButtonText" placeholder="الدخول للخدمة" />
                </div>

                <div class="form-group">
                    <label asp-for="DisplayOrder">الترتيب</label>
                    <input asp-for="DisplayOrder" type="number" />
                </div>

                <div class="form-group">
                    <label>صورة / أيقونة الخدمة</label>
                    <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.webp" />
                    <small>اختياري. المقاس المقترح 300×300.</small>
                </div>

                <div class="form-check">
                    <input asp-for="OpenInNewTab" />
                    <label asp-for="OpenInNewTab">فتح الرابط الخارجي في تبويب جديد</label>
                </div>

                <div class="form-check">
                    <input asp-for="IsActive" />
                    <label asp-for="IsActive">مفعل</label>
                </div>
            </div>

            <div class="form-actions">
                <button class="admin-submit-btn" type="submit">حفظ رابط الخدمة</button>
                <a href="/Admin/ServiceLinks">إلغاء</a>
            </div>
        </form>
    </div>

    <aside class="service-admin-note">
        <span>ملاحظة</span>
        <h2>القائمة في الهيدر</h2>
        <p>أي رابط تضيفه هنا ويكون مفعل سيظهر تلقائياً تحت زر الخدمات الإلكترونية أعلى الموقع.</p>
    </aside>
</div>

@section Scripts {
    <script>
        (function () {
            const select = document.getElementById("linkTypeSelect");
            const externalBox = document.querySelector(".link-external-box");
            const internalBox = document.querySelector(".link-internal-box");

            function refresh() {
                const isInternal = select.value === "Internal";
                externalBox.style.display = isInternal ? "none" : "";
                internalBox.style.display = isInternal ? "" : "none";
            }

            select.addEventListener("change", refresh);
            refresh();
        })();
    </script>
}





