y:block;height:100%;background:#4db748;border-radius:999px}.money-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}.money-grid div{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:12px}.money-grid span{display:block;color:#667085;font-weight:900;font-size:12px}.money-grid strong{display:block;margin-top:5px;color:#344054}.contribution-admin-forms{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:16px}.contribution-admin-forms form{background:#fff;border:1px solid #e5e7eb;border-radius:18px;padding:14px;display:grid;gap:10px}.contribution-admin-forms h4,.timeline-mini h4{margin:0;color:#6c5ca8}.contribution-admin-forms small{color:#667085;font-weight:800;line-height:1.6}.timeline-mini{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:16px}.timeline-mini>div,.simple-list>div{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:12px}.timeline-mini p,.simple-list p{margin:8px 0;color:#667085;font-weight:800;line-height:1.7}.timeline-mini p span,.simple-list span{display:block;color:#98a2b3;font-size:12px;font-weight:900}.simple-list{display:grid;gap:10px;max-height:420px;overflow:auto}.simple-list strong{color:#243018}.admin-alert-error{background:#fef3f2;border:1px solid #fecdca;color:#b42318;padding:14px 18px;border-radius:16px;margin-bottom:18px;font-weight:900}.admin-alert-success{background:#ecfdf3;border:1px solid #abefc6;color:#067647;padding:14px 18px;border-radius:16px;margin-bottom:18px;font-weight:900}@@media(max-width:1200px){.donor-admin-stats,.money-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.donor-admin-grid.two-cols,.contribution-admin-forms,.timeline-mini{grid-template-columns:1fr}}@@media(max-width:700px){.donor-admin-stats,.money-grid{grid-template-columns:1fr}.contribution-top,.panel-title{display:grid}.donor-info-list{grid-template-columns:1fr}.reject-details form{position:static;width:100%;margin-top:8px}}
.mini-action.certificate,.certificate-action{background:#fdf3d0!important;color:#8a5a00!important;border:0;border-radius:999px;padding:8px 12px;font-weight:900;text-decoration:none}.mini-action.certificate{cursor:pointer}.money-grid:has(div:nth-child(5)){grid-template-columns:repeat(5,minmax(0,1fr))}
</style>


