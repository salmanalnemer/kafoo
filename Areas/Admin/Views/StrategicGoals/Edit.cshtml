@model Kafo.Web.Models.StrategicGoal

@{
    ViewData["Title"] = "تعديل هدف";
}

<div class="admin-page-head">
    <div>
        <span>أهداف الجمعية</span>
        <h1>تعديل الهدف الاستراتيجي</h1>
        <p>عدّل عنوان الهدف أو وصفه أو ترتيبه في الصفحة الرئيسية.</p>
    </div>

    <a class="admin-back-link" href="/Admin/StrategicGoals">العودة للقائمة</a>
</div>

<div class="admin-form-card">
    <form method="post" class="admin-form">
        @Html.AntiForgeryToken()

        <input asp-for="Id" type="hidden" />
        <input asp-for="CreatedAt" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Title">عنوان الهدف</label>
                <input asp-for="Title" />
                <span asp-validation-for="Title"></span>
            </div>

            <div class="form-group">
                <label asp-for="Icon">الأيقونة</label>
                <input asp-for="Icon" />
                <small>مثال: ✓ أو fa-solid fa-bullseye</small>
            </div>

            <div class="form-group full">
                <label asp-for="Description">وصف الهدف</label>
                <textarea asp-for="Description" rows="4"></textarea>
                <span asp-validation-for="Description"></span>
            </div>

            <div class="form-group">
                <label asp-for="DisplayOrder">ترتيب الظهور</label>
                <input asp-for="DisplayOrder" type="number" />
            </div>

            <div class="form-check">
                <input asp-for="IsActive" />
                <label asp-for="IsActive">مفعل</label>
            </div>
        </div>

        <div class="form-actions">
            <button class="admin-submit-btn" type="submit">حفظ التعديل</button>
            <a href="/Admin/StrategicGoals">إلغاء</a>
        </div>
    </form>
</div>
