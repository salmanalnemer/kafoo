@model Kafo.Web.Models.NewsPost

@{
    ViewData["Title"] = "إضافة خبر";
}

<div class="admin-page-head">
    <div>
        <span>الأخبار</span>
        <h1>إضافة خبر جديد</h1>
        <p>الملخص يظهر في الكرت، والتفاصيل تظهر داخل صفحة الخبر.</p>
    </div>
    <a class="admin-back-link" href="/Admin/News">العودة</a>
</div>

<div class="admin-form-card">
    <form method="post" enctype="multipart/form-data" class="admin-form">
        @Html.AntiForgeryToken()

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Title">عنوان الخبر</label>
                <input asp-for="Title" />
                <span asp-validation-for="Title"></span>
            </div>

            <div class="form-group">
                <label asp-for="PublishDate">تاريخ النشر</label>
                <input asp-for="PublishDate" type="datetime-local" />
            </div>

            <div class="form-group">
                <label asp-for="Category">التصنيف</label>
                <input asp-for="Category" />
            </div>

            <div class="form-group">
                <label asp-for="Audience">الفئة</label>
                <input asp-for="Audience" />
            </div>

            <div class="form-group full">
                <label asp-for="Summary">ملخص الخبر للكرت</label>
                <textarea asp-for="Summary" rows="3"></textarea>
            </div>

            <div class="form-group full">
                <label asp-for="Details">تفاصيل الخبر الكاملة</label>
                <textarea asp-for="Details" rows="8"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="DisplayOrder">الترتيب</label>
                <input asp-for="DisplayOrder" type="number" />
            </div>

            <div class="form-group">
                <label>صورة الخبر</label>
                <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.webp" />
            </div>

            <div class="form-check full">
                <input asp-for="IsActive" />
                <label asp-for="IsActive">مفعل</label>
            </div>
        </div>

        <div class="form-actions">
            <button class="admin-submit-btn" type="submit">حفظ</button>
            <a href="/Admin/News">إلغاء</a>
        </div>
    </form>
</div>
