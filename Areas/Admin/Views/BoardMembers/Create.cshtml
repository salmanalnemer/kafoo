@model Kafo.Web.Models.BoardMember

@{
    ViewData["Title"] = "إضافة عضو مجلس الإدارة";
}

<div class="bm-admin-page">

    <div class="bm-admin-hero">
        <div>
            <span>ملفات الحوكمة</span>
            <h1>إضافة عضو مجلس الإدارة</h1>
            <p>أدخل بيانات العضو كما ستظهر في صفحة الحوكمة.</p>
        </div>

        <div class="bm-admin-actions">
            <a href="/Admin/BoardMembers">رجوع للأعضاء</a>
        </div>
    </div>

    <div class="bm-form-card">
        <form method="post" enctype="multipart/form-data" action="/Admin/BoardMembers/Create" class="bm-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="bm-form-grid">
                <div class="form-group">
                    <label>اسم العضو</label>
                    <input asp-for="FullName" placeholder="اسم العضو كامل" />
                    <span asp-validation-for="FullName"></span>
                </div>

                <div class="form-group">
                    <label>المنصب</label>
                    <input asp-for="PositionTitle" placeholder="رئيس مجلس الإدارة / نائب الرئيس / عضو..." />
                </div>

                <div class="form-group">
                    <label>الصفة</label>
                    <input asp-for="MembershipRole" placeholder="عضو منتخب / عضو معين / ممثل..." />
                </div>

                <div class="form-group">
                    <label>الدورة</label>
                    <input asp-for="BoardTerm" placeholder="مثال: دورة 2026 - 2029" />
                </div>

                <div class="form-group">
                    <label>بداية الدورة</label>
                    <input asp-for="TermStartDate" type="date" />
                </div>

                <div class="form-group">
                    <label>نهاية الدورة</label>
                    <input asp-for="TermEndDate" type="date" />
                </div>

                <div class="form-group">
                    <label>رقم الجوال</label>
                    <input asp-for="Phone" dir="ltr" placeholder="اختياري" />
                </div>

                <div class="form-group">
                    <label>البريد الإلكتروني</label>
                    <input asp-for="Email" dir="ltr" placeholder="اختياري" />
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="form-group">
                    <label>صورة العضو</label>
                    <input type="file" name="photoFile" accept=".jpg,.jpeg,.png,.webp,.gif,.jfif,.avif" />
                </div>

                <div class="form-group">
                    <label>الترتيب</label>
                    <input asp-for="DisplayOrder" type="number" />
                </div>

                <div class="form-group full">
                    <label>نبذة مختصرة</label>
                    <textarea asp-for="Bio" rows="4" placeholder="نبذة اختيارية عن العضو"></textarea>
                </div>

                <div class="form-check">
                    <input asp-for="IsChairman" />
                    <label>رئيس مجلس الإدارة</label>
                </div>

                <div class="form-check">
                    <input asp-for="IsFeatured" />
                    <label>عضو مميز</label>
                </div>

                <div class="form-check">
                    <input asp-for="IsActive" />
                    <label>إظهار العضو</label>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="admin-submit-btn">حفظ العضو</button>
            </div>
        </form>
    </div>

</div>
