@model Kafo.Web.ViewModels.Admin.AdminOrganizationDetailsViewModel
@{ ViewData["Title"] = "تفاصيل الجهة"; }
<div class="adm-users-hero"><div><span>ملف الجهة</span><h1>@Model.Organization.Name</h1><p>@(Model.Organization.Activity ?? "نشاط غير محدد") — @(Model.Organization.City ?? "مدينة غير محددة")</p></div><div class="adm-users-actions"><a href="/Admin/Organizations/Edit/@Model.Organization.Id">تعديل الحساب</a><a href="/Admin/Organizations">رجوع</a></div></div>
@if(TempData["Success"]!=null){<div class="admin-alert-success">@TempData["Success"]</div>}
@if(TempData["Error"]!=null){<div class="admin-alert-error">@TempData["Error"]</div>}
<div class="org-stats"><div><span>الطلبات</span><strong>@Model.Requests.Count</strong></div><div><span>إجمالي الفرص</span><strong>@Model.TotalOpportunities</strong></div><div><span>المرشحون</span><strong>@Model.Candidates.Count</strong></div><div><span>المقبولون</span><strong>@Model.AcceptedCandidates</strong></div><div><span>نسبة النجاح</span><strong>@Model.SuccessRate%</strong></div></div>
<div class="org-detail-grid">
<section class="adm-users-card org-panel"><h2>بيانات الجهة</h2><dl><div><dt>مسؤول التواصل</dt><dd>@(Model.Organization.ContactName??"-")</dd></div><div><dt>البريد</dt><dd dir="ltr">@(Model.Organization.Email??"-")</dd></div><div><dt>الجوال</dt><dd dir="ltr">@(Model.Organization.Phone??"-")</dd></div><div><dt>آخر دخول</dt><dd>@(Model.Organization.LastLoginAt?.ToString("yyyy/MM/dd HH:mm")??"-")</dd></div><div><dt>الحالة</dt><dd>@(Model.Organization.IsActive?"مفعل":"معطل")</dd></div></dl></section>
<section class="adm-users-card org-panel"><h2>إرسال إشعار للجهة</h2><form method="post" action="/Admin/Organizations/@Model.Organization.Id/Notify"><label>العنوان<input name="title" required maxlength="220" /></label><label>الرسالة<textarea name="message" required maxlength="1200"></textarea></label><button type="submit">إرسال الإشعار</button></form></section>
</div>
<div class="adm-users-card" style="margin-top:18px"><div class="org-card-head"><h2>طلبات الاستقطاب</h2></div><div class="adm-table-wrap"><table class="adm-users-table"><thead><tr><th>الطلب</th><th>النوع</th><th>الفرص</th><th>المرشحون</th><th>الحالة</th><th>التاريخ</th><th></th></tr></thead><tbody>@if(!Model.Requests.Any()){<tr><td colspan="7" style="text-align:center;padding:25px">لا توجد طلبات.</td></tr>}@foreach(var r in Model.Requests){<tr><td><strong>@r.Title</strong><span class="muted-line">@(r.City??"-")</span></td><td>@r.OpportunityType</td><td>@r.AvailableCount</td><td>@r.Candidates.Count</td><td><span class="org-badge">@r.Status</span></td><td>@r.CreatedAt.ToString("yyyy/MM/dd")</td><td><a href="/Admin/Organizations/Requests/@r.Id">إدارة الطلب</a></td></tr>}</tbody></table></div></div>
<div class="org-detail-grid" style="margin-top:18px">
<section class="adm-users-card org-panel"><h2>آخر الإشعارات</h2>@if(!Model.Notifications.Any()){<p>لا توجد إشعارات.</p>}@foreach(var n in Model.Notifications.Take(8)){<article class="org-note"><strong>@n.Title</strong><p>@n.Message</p><small>@n.CreatedAt.ToString("yyyy/MM/dd HH:mm")</small></article>}</section>
<section class="adm-users-card org-panel"><h2>تقييمات الخدمة</h2>@if(!Model.Evaluations.Any()){<p>لم تسجل الجهة تقييمًا حتى الآن.</p>}@foreach(var e in Model.Evaluations){<article class="org-note"><strong>@(e.OpportunityRequest?.Title??"تقييم عام")</strong><p>جودة الترشيحات: @e.CandidateQualityRate/5 — الخدمة: @e.ServiceRate/5</p><small>@e.Notes</small></article>}</section>
</div>
<style>.org-stats{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}.org-stats>div,.org-panel{background:#fff;border:1px solid #e4e7ec;border-radius:20px;padding:18px}.org-stats span{color:#667085;font-weight:900;font-size:12px}.org-stats strong{display:block;color:#4db748;font-size:24px;margin-top:6px}.org-detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px}.org-panel h2{margin:0 0 16px}.org-panel dl{margin:0;display:grid;gap:10px}.org-panel dl div{display:flex;justify-content:space-between;gap:15px;padding-bottom:10px;border-bottom:1px solid #eee}.org-panel dt{color:#667085;font-weight:800}.org-panel dd{margin:0;font-weight:900}.org-panel form{display:grid;gap:12px}.org-panel label{display:grid;gap:7px;font-weight:900}.org-panel input,.org-panel textarea{border:1px solid #d0d5dd;border-radius:13px;padding:11px;font:inherit}.org-panel textarea{min-height:90px}.org-panel button{border:0;border-radius:999px;background:#4db748;color:#fff;padding:11px;font-weight:900}.org-note{padding:12px 0;border-bottom:1px solid #eee}.org-note p{margin:5px 0;color:#475467}.org-note small{color:#667085}.org-card-head{padding:18px}.org-card-head h2{margin:0}.org-badge{display:inline-flex;padding:6px 10px;border-radius:999px;background:#ecfdf3;color:#027a48;font-weight:900;font-size:12px}.muted-line{display:block;color:#667085;font-size:12px;margin-top:4px}@@media(max-width:900px){.org-stats{grid-template-columns:repeat(2,1fr)}.org-detail-grid{grid-template-columns:1fr}}</style>

