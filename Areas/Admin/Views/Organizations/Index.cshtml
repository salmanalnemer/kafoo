@model Kafo.Web.ViewModels.Admin.AdminOrganizationsIndexViewModel
@{ ViewData["Title"] = "الشركات والجهات"; }
<div class="adm-users-hero org-hero"><div><span>الاستقطاب والتوظيف والفرص</span><h1>إدارة الشركات والجهات</h1><p>إدارة الحسابات، طلبات الاستقطاب، المرشحين ومراحل القبول من مكان واحد.</p></div><div class="adm-users-actions"><a class="primary" href="/Admin/Organizations/Create">إضافة جهة جديدة</a></div></div>
@if(TempData["Success"]!=null){<div class="admin-alert-success">@TempData["Success"]</div>}
@if(TempData["Error"]!=null){<div class="admin-alert-error">@TempData["Error"]</div>}
<div class="org-stats"><div><span>إجمالي الجهات</span><strong>@Model.TotalOrganizations</strong></div><div><span>الحسابات المفعلة</span><strong>@Model.ActiveOrganizations</strong></div><div><span>طلبات الاستقطاب</span><strong>@Model.TotalRequests</strong></div><div><span>بانتظار المراجعة</span><strong>@Model.PendingRequestsCount</strong></div><div><span>المرشحون</span><strong>@Model.TotalCandidates</strong></div><div><span>تم قبولهم</span><strong>@Model.AcceptedCandidates</strong></div></div>
@if(Model.PendingRequests.Any()){
<div class="adm-users-card" style="margin-bottom:18px"><div class="org-card-head"><div><h2>طلبات تحتاج مراجعة</h2><p>أحدث الطلبات الجديدة أو الموجودة قيد المراجعة.</p></div></div><div class="adm-table-wrap"><table class="adm-users-table"><thead><tr><th>الجهة</th><th>الفرصة</th><th>النوع</th><th>العدد</th><th>الحالة</th><th></th></tr></thead><tbody>@foreach(var r in Model.PendingRequests){<tr><td><strong>@r.OrganizationAccount?.Name</strong></td><td>@r.Title</td><td>@r.OpportunityType</td><td>@r.AvailableCount</td><td><span class="org-badge pending">@r.Status</span></td><td><a href="/Admin/Organizations/Requests/@r.Id">مراجعة</a></td></tr>}</tbody></table></div></div>}
<div class="adm-users-filter"><form method="get"><input name="q" value="@Model.Search" placeholder="ابحث باسم الجهة، النشاط، المدينة أو التواصل..."/><select name="status"><option value="">كل الحالات</option><option value="active" selected="@(Model.StatusFilter=="active")">مفعل</option><option value="disabled" selected="@(Model.StatusFilter=="disabled")">معطل</option></select><button type="submit">بحث</button><a href="/Admin/Organizations">مسح</a></form></div>
<div class="adm-users-card"><div class="adm-table-wrap"><table class="adm-users-table"><thead><tr><th>الجهة</th><th>النشاط / المدينة</th><th>التواصل</th><th>الطلبات</th><th>الفرص</th><th>آخر دخول</th><th>الحالة</th><th>الإجراءات</th></tr></thead><tbody>
@if(!Model.Organizations.Any()){<tr><td colspan="8" style="text-align:center;padding:30px">لا توجد جهات مطابقة.</td></tr>}
@foreach(var item in Model.Organizations){<tr><td class="adm-user-title"><strong>@item.Name</strong><span>#@item.Id</span></td><td><strong>@(item.Activity??"-")</strong><span class="muted-line">@(item.City??"-")</span></td><td><div dir="ltr">@(item.Email??"-")</div><div dir="ltr">@(item.Phone??"-")</div></td><td>@item.OpportunityRequests.Count</td><td>@item.OpportunityRequests.Sum(x=>x.AvailableCount)</td><td>@(item.LastLoginAt?.ToString("yyyy/MM/dd HH:mm")??"-")</td><td><span class="adm-status @(item.IsActive?"active":"disabled")">@(item.IsActive?"مفعل":"معطل")</span></td><td><div class="adm-row-actions"><a href="/Admin/Organizations/Details/@item.Id">التفاصيل</a><a href="/Admin/Organizations/Edit/@item.Id">تعديل</a></div></td></tr>}
</tbody></table></div></div>
<style>.org-stats{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:12px;margin-bottom:18px}.org-stats>div{background:#fff;border:1px solid #e4e7ec;border-radius:20px;padding:17px}.org-stats span{display:block;color:#667085;font-weight:900;font-size:12px}.org-stats strong{display:block;margin-top:8px;color:#4db748;font-size:24px}.org-card-head{padding:18px}.org-card-head h2{margin:0}.org-card-head p{margin:5px 0 0;color:#667085}.org-badge{display:inline-flex;padding:6px 10px;border-radius:999px;font-weight:900;font-size:12px;background:#f2f4f7}.org-badge.pending{background:#fff4e5;color:#b54708}.muted-line{display:block;color:#667085;font-size:12px;margin-top:4px}@@media(max-width:1200px){.org-stats{grid-template-columns:repeat(3,1fr)}}@@media(max-width:700px){.org-stats{grid-template-columns:repeat(2,1fr)}}</style>

