    <script>
        (function () {
            var sections = document.querySelectorAll(".kafo-menu-section");

            sections.forEach(function (section) {
                var visibleLinks = section.querySelectorAll('.kafo-menu-links a:not(.kafo-permission-hidden)');
                if (visibleLinks.length === 0) {
                    section.classList.add('kafo-permission-hidden');
                    return;
                }

                var key = "kafo-sidebar-" + section.getAttribute("data-section");
                var button = section.querySelector(".kafo-menu-title");
                var hasActive = section.querySelector("a.is-active") !== null;
                var saved = localStorage.getItem(key);

                if (saved === "closed" && !hasActive) {
                    section.classList.add("is-collapsed");
                }

                if (hasActive) {
                    section.classList.remove("is-collapsed");
                    localStorage.setItem(key, "open");
                }

                if (button) {
                    button.addEventListener("click", function () {
                        section.classList.toggle("is-collapsed");

                        localStorage.setItem(
                            key,
                            section.classList.contains("is-collapsed") ? "closed" : "open"
                        );
                    });
                }
            });
        })();
    </script>

    <div class="admin-bell-toast" data-admin-bell-toast></div>
