@using Kafo.Web.Data
@using Kafo.Web.Security
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext AdminDb

@{
    var title = ViewData["Title"]?.ToString() ?? "لوحة التحكم";
    var currentPath = Context.Request.Path.Value?.ToLowerInvariant() ?? "";

    var adminUserIdValue = User.Claims.FirstOrDefault(x => x.Type == "KafoAdminUserId")?.Value;
    var currentAdminUser = int.TryParse(adminUserIdValue, out var currentAdminUserId)
        ? await AdminDb.AdminUsers.AsNoTracking().FirstOrDefaultAsync(x => x.Id == currentAdminUserId && x.IsActive)
        : null;

    var currentAdminRole = currentAdminUser == null
        ? AdminRolePolicy.Supervisor
        : await AdminRolePolicy.ResolveRoleAsync(AdminDb, currentAdminUser);

    var hasFullAdminAccess = AdminRolePolicy.HasFullPageAccess(currentAdminRole);
    var allowedPagePaths = hasFullAdminAccess || currentAdminUser == null
        ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        : (await AdminDb.AdminPagePermissions
            .AsNoTracking()
            .Where(x => x.AdminUserId == currentAdminUser.Id && x.CanAccess)
            .Select(x => x.PagePath)
            .ToListAsync())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

    Func<string, string> active = url =>
    {
        var value = url.ToLowerInvariant();

        if (value == "/admin" || value == "/admin/")
            return currentPath == "/admin" || currentPath == "/admin/" ? "is-active" : "";

        return currentPath.StartsWith(value) ? "is-active" : "";
    };

    Func<string, bool> canAccess = url =>
    {
        if (hasFullAdminAccess || AdminRolePolicy.AlwaysAllowedPagePaths.Contains(AdminPagesCatalog.Normalize(url)))
            return true;

        var page = AdminPagesCatalog.Match(url);
        return page != null && allowedPagePaths.Contains(page.PagePath);
    };

    Func<string, string> navClass = url =>
        $"{active(url)} {(canAccess(url) ? "" : "kafo-permission-hidden")}".Trim();
}

