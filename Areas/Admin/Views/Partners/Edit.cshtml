@model Kafo.Web.Models.SuccessPartner

@{
    ViewData["Title"] = "تعديل شريك";
}

<div class="admin-page-head">
    <div>
        <span>شركاء النجاح</span>
        <h1>تعديل الشريك</h1>
        <p>تعديل اسم الشريك أو الشعار أو الترتيب.</p>
    </div>
    <a class="admin-back-link" href="/Admin/Partners">العودة</a>
</div>

<div class="admin-form-card">
    <form method="post" enctype="multipart/form-data" class="admin-form">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Name">اسم الشريك</label>
                <input asp-for="Name" />
                <span asp-validation-for="Name"></span>
            </div>

            <div class="form-group">
                <label asp-for="WebsiteUrl">رابط الموقع</label>
                <input asp-for="WebsiteUrl" />
            </div>

            <div class="form-group">
                <label asp-for="DisplayOrder">الترتيب</label>
                <input asp-for="DisplayOrder" type="number" />
            </div>

            <div class="form-group">
                <label>تغيير الشعار</label>
                <input type="file" name="logoFile" accept=".jpg,.jpeg,.png,.webp" />
            </div>

            <div class="form-check full">
                <input asp-for="IsActive" />
                <label asp-for="IsActive">مفعل</label>
            </div>
        </div>

        <div class="form-actions">
            <button class="admin-submit-btn" type="submit">حفظ التعديل</button>
            <a href="/Admin/Partners">إلغاء</a>
        </div>
    </form>
</div>
