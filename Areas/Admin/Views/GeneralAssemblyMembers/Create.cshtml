@model Kafo.Web.Models.GeneralAssemblyMember

@{
    ViewData["Title"] = "إضافة عضو جمعية عمومية";
}

<div class="gam-admin-page">

    <div class="gam-admin-hero">
        <div>
            <span>ملفات الحوكمة</span>
            <h1>إضافة عضو جمعية عمومية</h1>
            <p>أدخل بيانات العضو كما ستظهر في صفحة الحوكمة.</p>
        </div>

        <div class="gam-admin-actions">
            <a href="/Admin/GeneralAssemblyMembers">رجوع للأعضاء</a>
        </div>
    </div>

    <div class="gam-form-card">
        <form method="post" enctype="multipart/form-data" action="/Admin/GeneralAssemblyMembers/Create" class="gam-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="gam-form-grid">
                <div class="form-group">
                    <label>اسم العضو</label>
                    <input asp-for="FullName" placeholder="اسم العضو كامل" />
                    <span asp-validation-for="FullName"></span>
                </div>

                <div class="form-group">
                    <label>نوع العضوية</label>
                    <input asp-for="MembershipType" placeholder="عضو جمعية عمومية" />
                </div>

                <div class="form-group">
                    <label>المنصب / الصفة</label>
                    <input asp-for="PositionTitle" placeholder="رئيس / عضو / ممثل..." />
                </div>

                <div class="form-group">
                    <label>رقم العضوية</label>
                    <input asp-for="MembershipNumber" placeholder="اختياري" />
                </div>

                <div class="form-group">
                    <label>الدورة / الفترة</label>
                    <input asp-for="TermLabel" placeholder="مثال: دورة 2026 - 2029" />
                </div>

                <div class="form-group">
                    <label>تاريخ الانضمام</label>
                    <input asp-for="JoinedAt" type="date" />
                </div>

                <div class="form-group">
                    <label>صورة العضو</label>
                    <input type="file" name="photoFile" accept=".jpg,.jpeg,.png,.webp,.gif,.jfif,.avif" />
                </div>

                <div class="form-group">
                    <label>الترتيب</label>
                    <input asp-for="DisplayOrder" type="number" />
                </div>

                <div class="form-group full">
                    <label>نبذة مختصرة</label>
                    <textarea asp-for="Bio" rows="4" placeholder="نبذة اختيارية عن العضو"></textarea>
                </div>

                <div class="form-check">
                    <input asp-for="IsFeatured" />
                    <label>عضو مميز</label>
                </div>

                <div class="form-check">
                    <input asp-for="IsActive" />
                    <label>إظهار العضو</label>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="admin-submit-btn">حفظ العضو</button>
            </div>
        </form>
    </div>

</div>
