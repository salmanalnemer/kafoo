@model Kafo.Web.ViewModels.Admin.AdminLoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "تسجيل الدخول للوحة التحكم";
}

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>تسجيل الدخول | لوحة تحكم جمعية كفؤ</title>

    <style>
        :root {
            --kafo-green: #4cb748;
            --kafo-purple: #74429a;
            --kafo-dark: #26384d;
            --kafo-muted: #667085;
            --kafo-border: #e5e7eb;
            --kafo-bg: #f8fafc;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Tajawal", "Segoe UI", Tahoma, Arial, sans-serif;
            background:
                radial-gradient(circle at 15% 10%, rgba(76,183,72,.16), transparent 30%),
                radial-gradient(circle at 85% 90%, rgba(116,66,154,.16), transparent 32%),
                linear-gradient(135deg, #ffffff, #f8fafc);
            color: var(--kafo-dark);
            display: grid;
            place-items: center;
            padding: 24px;
        }

        .login-shell {
            width: min(1120px, 100%);
            min-height: 620px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            background: rgba(255,255,255,.86);
            border: 1px solid rgba(229,231,235,.9);
            border-radius: 34px;
            overflow: hidden;
            box-shadow: 0 28px 70px rgba(16,24,40,.13);
            backdrop-filter: blur(14px);
        }

        .login-brand {
            position: relative;
            padding: 48px;
            background: linear-gradient(145deg, var(--kafo-purple), #5d367c);
            color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow: hidden;
        }

        .login-brand::before {
            content: "";
            position: absolute;
            width: 340px;
            height: 340px;
            background: rgba(76,183,72,.28);
            border-radius: 999px;
            top: -90px;
            left: -90px;
        }

        .login-brand::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border: 34px solid rgba(255,255,255,.08);
            border-radius: 999px;
            bottom: -90px;
            right: -80px;
        }

        .brand-content,
        .brand-footer {
            position: relative;
            z-index: 2;
        }

        .brand-logo {
            width: 116px;
            height: 116px;
            border-radius: 28px;
            background: #fff;
            padding: 14px;
            display: grid;
            place-items: center;
            box-shadow: 0 18px 40px rgba(0,0,0,.16);
            margin-bottom: 28px;
        }

        .brand-logo img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .login-brand h1 {
            margin: 0 0 14px;
            font-size: 36px;
            font-weight: 900;
            line-height: 1.4;
        }

        .login-brand p {
            margin: 0;
            color: rgba(255,255,255,.82);
            font-size: 17px;
            line-height: 2;
            max-width: 430px;
            font-weight: 600;
        }

        .brand-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 42px;
            padding: 0 16px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.18);
            font-weight: 800;
            margin-top: 26px;
        }

        .brand-footer {
            font-size: 13px;
            color: rgba(255,255,255,.72);
            font-weight: 700;
        }

        .login-panel {
            padding: 56px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 100%;
            max-width: 430px;
        }

        .login-card h2 {
            margin: 0 0 10px;
            color: var(--kafo-dark);
            font-size: 30px;
            font-weight: 900;
        }

        .login-card .hint {
            margin: 0 0 28px;
            color: var(--kafo-muted);
            line-height: 1.8;
            font-weight: 700;
        }

        .field {
            margin-bottom: 18px;
        }

        .field label {
            display: block;
            margin-bottom: 8px;
            color: var(--kafo-dark);
            font-size: 14px;
            font-weight: 900;
        }

        .field input {
            width: 100%;
            min-height: 52px;
            border: 1px solid #d0d5dd;
            border-radius: 16px;
            padding: 0 16px;
            color: var(--kafo-dark);
            font-size: 15px;
            font-weight: 700;
            outline: none;
            background: #fff;
        }

        .field input:focus {
            border-color: var(--kafo-purple);
            box-shadow: 0 0 0 4px rgba(116,66,154,.10);
        }

        .remember-row {
            display: flex;
            align-items: center;
            gap: 9px;
            margin: 4px 0 22px;
            color: var(--kafo-muted);
            font-weight: 800;
        }

        .remember-row input {
            width: 18px;
            height: 18px;
        }

        .login-btn {
            width: 100%;
            min-height: 54px;
            border: 0;
            border-radius: 999px;
            background: linear-gradient(135deg, var(--kafo-purple), #8a56b0);
            color: #fff;
            font-size: 16px;
            font-weight: 900;
            cursor: pointer;
            box-shadow: 0 16px 34px rgba(116,66,154,.24);
        }

        .login-btn:hover {
            background: linear-gradient(135deg, var(--kafo-green), #3fa33d);
        }

        .validation-summary-errors {
            background: #fff7ed;
            border: 1px solid #fed7aa;
            color: #c2410c;
            border-radius: 14px;
            padding: 12px 14px;
            margin-bottom: 18px;
            font-weight: 800;
        }

        .field-validation-error {
            display: block;
            color: #dc2626;
            font-size: 13px;
            font-weight: 800;
            margin-top: 6px;
        }

        .default-note {
            margin-top: 18px;
            background: #f6fbf6;
            border: 1px solid #cdeecd;
            color: #3da143;
            border-radius: 14px;
            padding: 12px 14px;
            font-size: 13px;
            font-weight: 800;
            line-height: 1.8;
        }

        @@media (max-width: 900px) {
            .login-shell {
                grid-template-columns: 1fr;
            }

            .login-brand {
                padding: 34px;
            }

            .login-panel {
                padding: 34px;
            }
        }
    </style>
</head>
<body>

    <main class="login-shell">
        <section class="login-brand">
            <div class="brand-content">
                <div class="brand-logo">
                    <img src="/images/logo1.png" alt="شعار جمعية كفؤ" />
                </div>

                <h1>لوحة تحكم جمعية كفؤ</h1>
                <p>
                    دخول آمن لإدارة محتوى الموقع، الرسائل، الحوكمة، الفرص، والمشرفين حسب الصلاحيات المحددة.
                </p>

                <div class="brand-pill">إدارة موثوقة ومنظمة</div>
            </div>

            <div class="brand-footer">
                جميع العمليات داخل لوحة التحكم تخضع للصلاحيات.
            </div>
        </section>

        <section class="login-panel">
            <div class="login-card">
                <h2>تسجيل الدخول</h2>
                <p class="hint">أدخل بريدك الإلكتروني وكلمة المرور، ثم أدخل رمز التحقق المرسل إلى بريدك.</p>

                <form method="post" action="/Admin/Login">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="ReturnUrl" />

                    @if (TempData["LoginError"] is string loginError)
                    {
                        <div class="validation-summary-errors">@loginError</div>
                    }

                    <div asp-validation-summary="ModelOnly"></div>

                    <div class="field">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" type="email" autocomplete="email" dir="ltr" placeholder="name@example.com" />
                        <span asp-validation-for="Email"></span>
                    </div>

                    <div class="field">
                        <label>كلمة المرور</label>
                        <input asp-for="Password" type="password" autocomplete="current-password" />
                        <span asp-validation-for="Password"></span>
                    </div>

                    <label class="remember-row">
                        <input asp-for="RememberMe" />
                        <span>تذكرني على هذا الجهاز</span>
                    </label>

                    <button type="submit" class="login-btn">إرسال رمز التحقق</button>

                    <div class="default-note">
                       سيتم إرسال رمز تحقق من البريد support@kafoo.com.sa
                        
                    </div>
                </form>
            </div>
        </section>
    </main>

</body>
</html>

