@model Kafo.Web.Models.VolunteerOpportunity

@{
    ViewData["Title"] = "إضافة فرصة تطوعية";
}

<div class="vo-admin-page">

    <div class="vo-admin-hero">
        <div>
            <span>التطوع والتوظيف</span>
            <h1>إضافة فرصة تطوعية</h1>
            <p>أدخل بيانات الفرصة التطوعية كما ستظهر في الموقع.</p>
        </div>

        <div class="vo-admin-actions">
            <a href="/Admin/VolunteerOpportunities">رجوع للفرص</a>
        </div>
    </div>

    <div class="vo-form-card">
        <form method="post" enctype="multipart/form-data" action="/Admin/VolunteerOpportunities/Create" class="vo-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="vo-form-grid">
                <div class="form-group">
                    <label>عنوان الفرصة</label>
                    <input asp-for="Title" placeholder="مثال: تنظيم فعالية اليوم العالمي" />
                    <span asp-validation-for="Title"></span>
                </div>

                <div class="form-group">
                    <label>نوع الفرصة</label>
                    <input asp-for="OpportunityType" placeholder="فرصة تطوعية / مبادرة / تنظيم..." />
                </div>

                <div class="form-group">
                    <label>الموقع</label>
                    <input asp-for="Location" placeholder="مثال: مقر الجمعية / المدينة..." />
                </div>

                <div class="form-group">
                    <label>رابط التسجيل</label>
                    <input asp-for="RegistrationUrl" dir="ltr" placeholder="https://..." />
                </div>

                <div class="form-group">
                    <label>تاريخ البداية</label>
                    <input asp-for="StartDate" type="date" />
                </div>

                <div class="form-group">
                    <label>تاريخ النهاية</label>
                    <input asp-for="EndDate" type="date" />
                </div>

                <div class="form-group">
                    <label>عدد الساعات التطوعية</label>
                    <input asp-for="VolunteerHours" type="number" min="0" />
                </div>

                <div class="form-group">
                    <label>عدد المقاعد</label>
                    <input asp-for="SeatsCount" type="number" min="0" />
                </div>

                <div class="form-group">
                    <label>صورة الفرصة</label>
                    <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.webp,.gif,.jfif,.avif" />
                </div>

                <div class="form-group">
                    <label>الترتيب</label>
                    <input asp-for="DisplayOrder" type="number" />
                </div>

                <div class="form-group full">
                    <label>وصف الفرصة</label>
                    <textarea asp-for="Description" rows="4" placeholder="وصف مختصر عن الفرصة"></textarea>
                </div>

                <div class="form-group full">
                    <label>المتطلبات</label>
                    <textarea asp-for="Requirements" rows="4" placeholder="المهارات أو المتطلبات المطلوبة"></textarea>
                </div>

                <div class="form-check">
                    <input asp-for="IsRemote" />
                    <label>فرصة عن بعد</label>
                </div>

                <div class="form-check">
                    <input asp-for="IsFeatured" />
                    <label>فرصة مميزة</label>
                </div>

                <div class="form-check">
                    <input asp-for="IsActive" />
                    <label>إظهار الفرصة</label>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="admin-submit-btn">حفظ الفرصة</button>
            </div>
        </form>
    </div>

</div>
