@model Kafo.Web.Models.BankAccount

@{
    ViewData["Title"] = "إضافة حساب بنكي";
}

<div class="admin-page-head">
    <div>
        <span>الحسابات البنكية</span>
        <h1>إضافة حساب بنكي</h1>
        <p>أدخل بيانات الحساب البنكي الرسمي للجمعية.</p>
    </div>

    <a class="admin-back-link" href="/Admin/BankAccounts">العودة للقائمة</a>
</div>

<div class="bank-form-layout">
    <div class="admin-form-card">
        <form method="post" enctype="multipart/form-data" class="admin-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="BankName">اسم البنك</label>
                    <input asp-for="BankName" placeholder="مثال: مصرف الراجحي" />
                    <span asp-validation-for="BankName"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AccountName">اسم الحساب</label>
                    <input asp-for="AccountName" />
                    <span asp-validation-for="AccountName"></span>
                </div>

                <div class="form-group full">
                    <label asp-for="Iban">رقم الآيبان</label>
                    <input asp-for="Iban" dir="ltr" placeholder="SA0000000000000000000000" />
                    <span asp-validation-for="Iban"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AccountNumber">رقم الحساب</label>
                    <input asp-for="AccountNumber" dir="ltr" placeholder="اختياري" />
                </div>

                <div class="form-group">
                    <label asp-for="DisplayOrder">الترتيب</label>
                    <input asp-for="DisplayOrder" type="number" />
                </div>

                <div class="form-group full">
                    <label>شعار البنك</label>
                    <input type="file" name="logoFile" accept=".jpg,.jpeg,.png,.webp" />
                    <small>اختياري. المسموح صورة فقط.</small>
                </div>

                <div class="form-check full">
                    <input asp-for="IsActive" />
                    <label asp-for="IsActive">مفعل</label>
                </div>
            </div>

            <div class="form-actions">
                <button class="admin-submit-btn" type="submit">حفظ الحساب</button>
                <a href="/Admin/BankAccounts">إلغاء</a>
            </div>
        </form>
    </div>

    <aside class="bank-admin-note">
        <span>تنبيه</span>
        <h2>تأكد من رقم الآيبان</h2>
        <p>سيظهر رقم الآيبان في الموقع العام مع زر نسخ مباشر للزوار والداعمين.</p>
    </aside>
</div>
