@model Kafo.Web.Models.BankAccount

@{
    ViewData["Title"] = "تعديل حساب بنكي";
}

<div class="admin-page-head">
    <div>
        <span>الحسابات البنكية</span>
        <h1>تعديل الحساب البنكي</h1>
        <p>تعديل بيانات البنك أو استبدال الشعار.</p>
    </div>

    <a class="admin-back-link" href="/Admin/BankAccounts">العودة للقائمة</a>
</div>

<div class="bank-form-layout">
    <div class="admin-form-card">
        <form method="post" enctype="multipart/form-data" class="admin-form">
            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />
            <input asp-for="LogoPath" type="hidden" />
            <input asp-for="CreatedAt" type="hidden" />
            <input asp-for="UpdatedAt" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            @if (!string.IsNullOrWhiteSpace(Model.LogoPath))
            {
                <div class="admin-image-preview">
                    <span>الشعار الحالي</span>
                    <img src="@Model.LogoPath" alt="@Model.BankName" />
                </div>
            }

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="BankName">اسم البنك</label>
                    <input asp-for="BankName" />
                    <span asp-validation-for="BankName"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AccountName">اسم الحساب</label>
                    <input asp-for="AccountName" />
                    <span asp-validation-for="AccountName"></span>
                </div>

                <div class="form-group full">
                    <label asp-for="Iban">رقم الآيبان</label>
                    <input asp-for="Iban" dir="ltr" />
                    <span asp-validation-for="Iban"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AccountNumber">رقم الحساب</label>
                    <input asp-for="AccountNumber" dir="ltr" />
                </div>

                <div class="form-group">
                    <label asp-for="DisplayOrder">الترتيب</label>
                    <input asp-for="DisplayOrder" type="number" />
                </div>

                <div class="form-group full">
                    <label>استبدال شعار البنك</label>
                    <input type="file" name="logoFile" accept=".jpg,.jpeg,.png,.webp" />
                    <small>اتركه فارغاً للاحتفاظ بالشعار الحالي.</small>
                </div>

                <div class="form-check full">
                    <input asp-for="IsActive" />
                    <label asp-for="IsActive">مفعل</label>
                </div>
            </div>

            <div class="form-actions">
                <button class="admin-submit-btn" type="submit">حفظ التعديل</button>
                <a href="/Admin/BankAccounts">إلغاء</a>
            </div>
        </form>
    </div>

    <aside class="bank-admin-note">
        <span>معاينة</span>
        <h2>@Model.BankName</h2>
        <p dir="ltr">@Model.Iban</p>
    </aside>
</div>
