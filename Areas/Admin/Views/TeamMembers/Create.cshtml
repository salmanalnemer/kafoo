@model Kafo.Web.Models.TeamMember

@{
    ViewData["Title"] = "إضافة عضو فريق";
}

<div class="admin-page-head">
    <div>
        <span>فريق العمل</span>
        <h1>إضافة عضو جديد</h1>
        <p>أدخل بيانات عضو الفريق ليظهر في صفحة فريق العمل.</p>
    </div>

    <a class="admin-back-link" href="/Admin/TeamMembers">العودة للقائمة</a>
</div>

<div class="team-admin-layout">
    <div class="admin-form-card">
        <form method="post" enctype="multipart/form-data" class="admin-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="FullName">اسم عضو الفريق</label>
                    <input asp-for="FullName" placeholder="اكتب الاسم" />
                    <span asp-validation-for="FullName"></span>
                </div>

                <div class="form-group">
                    <label asp-for="JobTitle">المسمى الوظيفي</label>
                    <input asp-for="JobTitle" placeholder="مثال: مدير البرامج" />
                    <span asp-validation-for="JobTitle"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">البريد الإلكتروني</label>
                    <input asp-for="Email" placeholder="name@example.com" />
                </div>

                <div class="form-group">
                    <label asp-for="Phone">رقم الجوال</label>
                    <input asp-for="Phone" placeholder="05xxxxxxxx" />
                </div>

                <div class="form-group">
                    <label asp-for="DisplayOrder">الترتيب</label>
                    <input asp-for="DisplayOrder" type="number" />
                </div>

                <div class="form-group">
                    <label>صورة العضو</label>
                    <input type="file" name="imageFile" accept=".jpg,.jpeg,.png,.webp" />
                    <small>المقاس المقترح 600×700 أو صورة شخصية واضحة.</small>
                </div>

                <div class="form-group full">
                    <label asp-for="Bio">نبذة مختصرة</label>
                    <textarea asp-for="Bio" rows="5" placeholder="نبذة مختصرة تظهر داخل الكرت"></textarea>
                </div>

                <div class="form-check full">
                    <input asp-for="IsActive" />
                    <label asp-for="IsActive">مفعل</label>
                </div>
            </div>

            <div class="form-actions">
                <button class="admin-submit-btn" type="submit">حفظ العضو</button>
                <a href="/Admin/TeamMembers">إلغاء</a>
            </div>
        </form>
    </div>

    <aside class="team-admin-side-note">
        <span>ملاحظة</span>
        <h2>صورة فريق العمل</h2>
        <p>يفضّل استخدام صورة شخصية بخلفية واضحة، وسيتم عرضها بشكل كرت رسمي داخل الموقع العام.</p>
    </aside>
</div>
