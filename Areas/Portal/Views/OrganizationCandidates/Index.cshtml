@model IEnumerable<OpportunityCandidate>
@{ViewData["Title"]="المرشحون";}
<section class="org-hero"><div><h2>إدارة المرشحين</h2><p>استعرض المرشحين الذين رشحتهم الجمعية وتابع نتيجة التواصل والمقابلات.</p></div><a class="portal-btn" href="/Portal/Organization/OpportunityRequests">عرض الطلبات</a></section>
<section class="portal-panel"><div class="portal-panel-head"><div><h2>جميع المرشحين</h2><p>@Model.Count() مرشحًا ضمن طلبات الجهة.</p></div><form method="get"><select name="status" data-auto-submit="true"><option value="">كل الحالات</option>@foreach(var s in new[]{"مرشح جديد","تم التواصل","تمت المقابلة","تم القبول","لم يتم القبول"}){<option value="@s" selected="@(ViewBag.Status==s)">@s</option>}</select></form></div>
@if(!Model.Any()){<div class="portal-empty">لا يوجد مرشحون حتى الآن.</div>}else{<div class="org-candidates">@foreach(var c in Model){<article class="org-candidate"><div class="org-candidate-head"><div><h3>@c.CandidateName</h3><small>@c.OpportunityRequest?.Title</small></div><span class="org-status">@c.Status</span></div><div class="org-tags"><span>@c.OpportunityRequest?.OpportunityType</span><span>@(c.OpportunityRequest?.City??"مدينة غير محددة")</span></div><p><strong>المؤهلات:</strong> @(c.Qualifications??"غير محددة")</p><p><strong>المهارات:</strong> @(c.Skills??"غير محددة")</p><div class="org-report-actions">@if(!string.IsNullOrWhiteSpace(c.CvFilePath)){<a class="portal-btn light" href="@c.CvFilePath" target="_blank" rel="noopener noreferrer">السيرة الذاتية</a>}<a class="portal-btn" href="/Portal/Organization/OpportunityRequests/Details/@c.OpportunityRequestId">إدارة المرشح</a></div></article>}</div>}</section>
