@model IEnumerable<OpportunityRequest>
@{Layout=null;var org=(OrganizationAccount)ViewBag.Organization;var accepted=Model.Sum(x=>x.Candidates.Count(c=>c.Status=="تم القبول"));}
<!doctype html><html lang="ar" dir="rtl"><head><meta charset="utf-8"><title>تقرير الاستقطاب</title><link rel="stylesheet" href="/css/portal-area.css"><link rel="stylesheet" href="/css/organization-portal.css"></head><body><div class="no-print" style="padding:12px;text-align:center"><button data-browser-action="print">طباعة / حفظ PDF</button></div><main class="org-print"><header style="display:flex;justify-content:space-between;border-bottom:3px solid #7c3aed;padding-bottom:15px"><div><h1>تقرير الاستقطاب والتوظيف</h1><p>@org.Name — @DateTime.Now.ToString("yyyy/MM/dd")</p></div>@if(!string.IsNullOrWhiteSpace(org.LogoPath)){<img src="@org.LogoPath" style="width:75px;height:75px;object-fit:contain">}</header><section class="org-kpis" style="margin-top:20px"><article class="org-kpi"><span>الطلبات</span><strong>@Model.Count()</strong></article><article class="org-kpi"><span>الفرص</span><strong>@Model.Sum(x=>x.AvailableCount)</strong></article><article class="org-kpi"><span>المرشحون</span><strong>@Model.Sum(x=>x.Candidates.Count)</strong></article><article class="org-kpi"><span>المقبولون</span><strong>@accepted</strong></article></section>@foreach(var x in Model){<section style="margin:18px 0;break-inside:avoid-page"><h2>@x.Title</h2><table><tr><th>نوع الفرصة</th><td>@x.OpportunityType</td><th>الحالة</th><td>@x.Status</td></tr><tr><th>المدينة</th><td>@x.City</td><th>طبيعة العمل</th><td>@x.WorkNature</td></tr><tr><th>عدد الفرص</th><td>@x.AvailableCount</td><th>عدد المرشحين</th><td>@x.Candidates.Count</td></tr></table>@if(x.Candidates.Any()){<h3>المرشحون</h3><table><thead><tr><th>الاسم</th><th>الحالة</th><th>المؤهلات</th></tr></thead><tbody>@foreach(var c in x.Candidates){<tr><td>@c.CandidateName</td><td>@c.Status</td><td>@c.Qualifications</td></tr>}</tbody></table>}</section>}<footer style="margin-top:30px;border-top:1px solid #ddd;padding-top:10px">صدر إلكترونيًا من بوابة الشركات والجهات — جمعية كفو</footer></main>    <script src="/js/security-ui.js" defer></script>
</body></html>
