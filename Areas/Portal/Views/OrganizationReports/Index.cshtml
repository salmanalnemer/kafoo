@model IEnumerable<OpportunityRequest>
@{ViewData["Title"]="تقارير الاستقطاب";var accepted=Model.Sum(x=>x.Candidates.Count(c=>c.Status=="تم القبول"));}
<section class="org-hero"><div><h2>التقارير والإحصائيات</h2><p>تقارير فردية أو شاملة لجميع طلبات الاستقطاب والمرشحين ونتائج القبول.</p></div><a class="portal-btn" href="/Portal/Organization/Reports/Print" target="_blank" rel="noopener noreferrer">طباعة التقرير الشامل</a></section>
<section class="org-kpis"><article class="org-kpi"><span>إجمالي الطلبات</span><strong>@Model.Count()</strong></article><article class="org-kpi"><span>إجمالي الفرص</span><strong>@Model.Sum(x=>x.AvailableCount)</strong></article><article class="org-kpi"><span>المرشحون</span><strong>@Model.Sum(x=>x.Candidates.Count)</strong></article><article class="org-kpi"><span>المقبولون</span><strong>@accepted</strong></article></section>
<section class="portal-panel"><div class="portal-table-wrap"><table class="portal-table"><thead><tr><th>الطلب</th><th>النوع</th><th>الفرص</th><th>المرشحون</th><th>المقبولون</th><th>الحالة</th><th></th></tr></thead><tbody>@foreach(var x in Model){<tr><td><strong>@x.Title</strong><small>@x.CreatedAt.ToString("yyyy/MM/dd")</small></td><td>@x.OpportunityType</td><td>@x.AvailableCount</td><td>@x.Candidates.Count</td><td>@x.Candidates.Count(c=>c.Status=="تم القبول")</td><td><span class="portal-badge">@x.Status</span></td><td><a class="portal-link" href="/Portal/Organization/Reports/Print/@x.Id" target="_blank" rel="noopener noreferrer">التقرير</a></td></tr>}</tbody></table></div></section>
