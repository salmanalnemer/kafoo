@model IEnumerable<OrganizationEvaluation>
@{ViewData["Title"]="تقييم الخدمة";var requests=(IEnumerable<OpportunityRequest>)ViewBag.Requests;}
<section class="org-grid-2"><section class="portal-panel"><div class="portal-panel-head"><div><h2>تقييم تجربة الاستقطاب</h2><p>ساعدنا في تطوير جودة الترشيحات والخدمة المقدمة.</p></div></div><form method="post" action="/Portal/Organization/Evaluations" class="portal-form">@Html.AntiForgeryToken()<div class="portal-form-grid"><div class="span-2"><label>الطلب المرتبط</label><select name="opportunityRequestId"><option value="">تقييم عام للخدمة</option>@foreach(var r in requests){<option value="@r.Id">@r.Title</option>}</select></div><div><label>جودة الترشيحات</label><select name="candidateQualityRate">@for(var i=5;i>=1;i--){<option value="@i">@i من 5</option>}</select></div><div><label>مستوى الخدمة</label><select name="serviceRate">@for(var i=5;i>=1;i--){<option value="@i">@i من 5</option>}</select></div><div class="span-2"><label>الملاحظات والمقترحات</label><textarea name="notes" rows="5" maxlength="1500"></textarea></div></div><div class="portal-actions"><button type="submit">إرسال التقييم</button></div></form></section><section class="portal-panel"><h2>التقييمات السابقة</h2>@if(!Model.Any()){<div class="portal-empty">لا توجد تقييمات سابقة.</div>}else{<div class="portal-timeline">@foreach(var x in Model){<article><strong>@(x.OpportunityRequest?.Title??"تقييم عام")</strong><p>جودة الترشيحات: @x.CandidateQualityRate/5 — الخدمة: @x.ServiceRate/5</p><small>@x.CreatedAt.ToString("yyyy/MM/dd")</small></article>}</div>}</section></section>
