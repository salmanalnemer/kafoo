@model Kafo.Web.Models.PresidentMessage

@{
    ViewData["Title"] = "كلمة رئيس الجمعية";
}

<section class="president-public-page">
    <div class="home-container">
        <div class="president-public-hero">
            <div class="president-public-image">
                @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" alt="@Model.LeaderName" />
                }
                else
                {
                    <div class="president-placeholder">
                        <span>صورة</span>
                        <strong>رئيس الجمعية</strong>
                    </div>
                }
            </div>

            <div class="president-public-content">
                <span>عن الجمعية</span>
                <h1>@Model.Title</h1>

                <div class="president-person">
                    <strong>@Model.LeaderName</strong>
                    <small>@Model.PositionTitle</small>
                </div>

                <div class="president-message-text">
                    <span style="white-space:pre-line">@Model.MessageText</span>
                </div>
            </div>
        </div>
    </div>
</section>
