@model Kafo.Web.Models.LicenseDocument

@{
    ViewData["Title"] = Model.Title;
}

<section class="license-details-page">
    <div class="home-container">
        <div class="license-details-head">
            <div>
                <span>تراخيص الجمعية</span>
                <h1>@Model.Title</h1>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p>@Model.Description</p>
                }
            </div>

            <a href="/Licenses">العودة للتراخيص</a>
        </div>

        <div class="license-direct-viewer">
            @if (Model.FileType == "pdf")
            {
                <iframe src="@Model.FilePath" title="@Model.Title"></iframe>
            }
            else
            {
                <img src="@Model.FilePath" alt="@Model.Title" />
            }
        </div>
    </div>
</section>
