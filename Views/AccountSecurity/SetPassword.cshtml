@model Kafo.Web.ViewModels.Authentication.SetPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "إعداد كلمة المرور";
}
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>إعداد كلمة المرور | جمعية كفو</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-light">
<main class="container py-5" style="max-width:620px">
    <section class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
        <h1 class="h3 mb-2">إعداد كلمة المرور</h1>
        <p class="text-muted">@Model.AccountLabel — @Model.DisplayName</p>
        <form method="post" action="/Account/SetPassword" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="Token" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">كلمة المرور الجديدة</label>
                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" minlength="12" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">تأكيد كلمة المرور</label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" minlength="12" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <p class="small text-muted">استخدم 12 حرفًا على الأقل، تشمل حرفًا كبيرًا وصغيرًا ورقمًا ورمزًا خاصًا.</p>
            <button class="btn btn-primary w-100" type="submit">حفظ كلمة المرور</button>
        </form>
    </section>
</main>
</body>
</html>
