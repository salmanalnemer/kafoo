@model IReadOnlyList<Kafo.Web.Models.VisionMissionCard>

@{
    ViewData["Title"] = "الرؤية والرسالة";
}

@functions {
    private Microsoft.AspNetCore.Html.IHtmlContent RenderVisionIcon(string? icon)
    {
        var key = (icon ?? "").ToLowerInvariant();

        string svg;

        if (key.Contains("envelope"))
        {
            svg = "<svg viewBox='0 0 24 24'><rect x='3' y='5' width='18' height='14' rx='2'></rect><path d='M3 7l9 6 9-6'></path></svg>";
        }
        else if (key.Contains("gem"))
        {
            svg = "<svg viewBox='0 0 24 24'><path d='M6 3h12l4 6-10 12L2 9l4-6z'></path><path d='M2 9h20'></path><path d='M12 21L8 9l4-6 4 6-4 12z'></path></svg>";
        }
        else if (key.Contains("heart"))
        {
            svg = "<svg viewBox='0 0 24 24'><path d='M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z'></path></svg>";
        }
        else if (key.Contains("award"))
        {
            svg = "<svg viewBox='0 0 24 24'><circle cx='12' cy='8' r='5'></circle><path d='M8.5 12.5L7 22l5-3 5 3-1.5-9.5'></path></svg>";
        }
        else if (key.Contains("star"))
        {
            svg = "<svg viewBox='0 0 24 24'><path d='M12 2l3.1 6.3 6.9 1-5 4.9 1.2 6.8L12 17.8 5.8 21 7 14.2 2 9.3l6.9-1L12 2z'></path></svg>";
        }
        else if (key.Contains("bullseye"))
        {
            svg = "<svg viewBox='0 0 24 24'><circle cx='12' cy='12' r='9'></circle><circle cx='12' cy='12' r='5'></circle><circle cx='12' cy='12' r='1.5'></circle></svg>";
        }
        else if (key.Contains("people") || key.Contains("users"))
        {
            svg = "<svg viewBox='0 0 24 24'><circle cx='9' cy='8' r='3'></circle><circle cx='17' cy='9' r='2.5'></circle><path d='M3 20c.6-4 3-6 6-6s5.4 2 6 6'></path><path d='M14 15c2.8.2 4.8 1.9 5.5 5'></path></svg>";
        }
        else if (key.Contains("lightbulb"))
        {
            svg = "<svg viewBox='0 0 24 24'><path d='M9 18h6'></path><path d='M10 22h4'></path><path d='M8 14a6 6 0 1 1 8 0c-1 1-1 2-1 4H9c0-2 0-3-1-4z'></path></svg>";
        }
        else if (key.Contains("seedling"))
        {
            svg = "<svg viewBox='0 0 24 24'><path d='M12 21V10'></path><path d='M12 10c-4 0-7-2-8-6 4 0 7 2 8 6z'></path><path d='M12 13c4 0 7-2 8-6-4 0-7 2-8 6z'></path></svg>";
        }
        else if (key.Contains("shield"))
        {
            svg = "<svg viewBox='0 0 24 24'><path d='M12 2l8 4v6c0 5-3.4 8.5-8 10-4.6-1.5-8-5-8-10V6l8-4z'></path><path d='M9 12l2 2 4-4'></path></svg>";
        }
        else
        {
            svg = "<svg viewBox='0 0 24 24'><path d='M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12z'></path><circle cx='12' cy='12' r='3'></circle></svg>";
        }

        return new Microsoft.AspNetCore.Html.HtmlString(svg);
    }
}

<section class="vision-public-page">
    <div class="home-container">
        <div class="vision-page-head">
            <span>عن الجمعية</span>
            <h1>الرؤية والرسالة والقيم</h1>
            <p>مرتكزاتنا التي ننطلق منها في تمكين ذوي الإعاقة وتعزيز جودة حياتهم.</p>
        </div>

        <div class="vision-public-grid">
            @foreach (var item in Model)
            {
                <article class="vision-public-card">
                    <div class="vision-public-icon">
                        @RenderVisionIcon(item.Icon)
                    </div>

                    <h2>@item.Title</h2>

                    <div class="vision-public-content">
                        <span style="white-space:pre-line">@item.Content</span>
                    </div>
                </article>
            }
        </div>
    </div>
</section>
